generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Post {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String
  content     String
  coverImage  String
  category    String
  author      String   @default("Asterix Studio")
  publishedAt DateTime @default(now())
  readTime    String
  isPublished Boolean  @default(true)
}
